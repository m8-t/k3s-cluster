# k3s config for bootstrap master — initializes embedded etcd cluster
cluster-init: true
token: "{{ k3s_token }}"

# TLS SANs for the API server cert
tls-san:
  - "{{ kube_vip_ip }}"
{% for ip in master_ips %}
  - "{{ ip }}"
{% endfor %}
{% for hostname in master_hostnames %}
  - "{{ hostname }}"
{% endfor %}

# Make kubeconfig world-readable so the debian user can read it
write-kubeconfig-mode: "0644"

disable:
  - servicelb
