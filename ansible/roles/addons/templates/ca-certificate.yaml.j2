apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: k3s-ca
  namespace: cert-manager
spec:
  isCA: true
  commonName: k3s-ca
  secretName: k3s-ca-secret
  duration: 87600h   # 10 years
  renewBefore: 720h  # 30 days
  privateKey:
    algorithm: ECDSA
    size: 256
  issuerRef:
    name: selfsigned-issuer
    kind: ClusterIssuer
    group: cert-manager.io
